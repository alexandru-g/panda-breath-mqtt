# Panda Breath MQTT Bridge configuration
# Copy to .env and adjust values, or set as environment variables with PB_ prefix.

PB_WS_HOST=pandabreath.local
PB_MQTT_HOST=localhost
PB_MQTT_PORT=1883
# PB_MQTT_USERNAME=
# PB_MQTT_PASSWORD=
PB_DEVICE_ID=panda_breath
PB_DEVICE_NAME=Panda Breath
PB_LOG_LEVEL=INFO
